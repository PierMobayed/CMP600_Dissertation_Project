# Copy to `.env` or `.env.local` as needed (do not commit real secrets).
# Vite reads only variables prefixed with VITE_.

# Public API root INCLUDING /api/v1 (must match FastAPI mount).
# Local dev:
# VITE_API_URL=http://127.0.0.1:8000/api/v1
# Cloud (example):
# VITE_API_URL=https://your-backend.up.railway.app/api/v1

VITE_API_URL=http://127.0.0.1:8000/api/v1

# Optional: match backend env API_BEARER_TOKEN if you change it server-side;
# frontends currently use login + default token from README unless you wire this in code.
# VITE_API_BEARER_TOKEN=cmp600-demo-token

# Backend only (create Source_Code/backend/.env):
# GETADDRESS_API_KEY=your_key_from_getaddress.io
